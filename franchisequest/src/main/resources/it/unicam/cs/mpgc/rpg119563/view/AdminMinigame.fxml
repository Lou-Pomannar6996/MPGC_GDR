<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unicam.cs.mpgc.rpg119563.view.minigame.AdminMinigameController"
      prefWidth="520" prefHeight="500"
      style="-fx-padding: 18; -fx-background-color: #edf2ff; -fx-alignment: top-center; -fx-spacing: 10;">

    <!-- PANNELLO INTRO -->
    <VBox fx:id="introPanel" spacing="10" style="-fx-alignment: top-center;">
        <Label fx:id="characterNameLabel"
               style="-fx-font-size: 22; -fx-font-weight: bold;"/>
        <Label fx:id="eventInfoLabel" wrapText="true" prefWidth="480"
               style="-fx-font-size: 14; -fx-border-color: #aaa; -fx-border-radius: 4;
                      -fx-background-color: #fffff0; -fx-padding: 8;"/>
        <Label fx:id="rulesLabel" wrapText="true" prefWidth="480"
               style="-fx-font-size: 13; -fx-border-color: #aaa; -fx-border-radius: 4;
                      -fx-background-color: #f0f0ff; -fx-padding: 8;"/>
        <Button text="INIZIA!" prefWidth="160" prefHeight="44"
                onAction="#onStart"
                style="-fx-font-size: 16; -fx-font-weight: bold;"/>
    </VBox>

    <!-- PANNELLO DI GIOCO -->
    <VBox fx:id="gamePanel" spacing="12"
          visible="false" managed="false"
          style="-fx-alignment: top-center;">
        <Label fx:id="questionLabel" text=" " wrapText="true" prefWidth="480"
               style="-fx-font-size: 15; -fx-border-color: #aab; -fx-border-radius: 4;
                      -fx-background-color: #f8f8ff; -fx-padding: 10;"/>
        <VBox spacing="8" style="-fx-alignment: center;">
            <Button fx:id="answerA" prefWidth="470" prefHeight="44"
                    onAction="#onAnswer" style="-fx-font-size: 13;"/>
            <Button fx:id="answerB" prefWidth="470" prefHeight="44"
                    onAction="#onAnswer" style="-fx-font-size: 13;"/>
            <Button fx:id="answerC" prefWidth="470" prefHeight="44"
                    onAction="#onAnswer" style="-fx-font-size: 13;"/>
            <Button fx:id="answerD" prefWidth="470" prefHeight="44"
                    onAction="#onAnswer" style="-fx-font-size: 13;"/>
        </VBox>
        <Label fx:id="resultLabel" text=" " wrapText="true" prefWidth="480"
               style="-fx-font-size: 14; -fx-font-weight: bold;"/>
    </VBox>
</VBox>
